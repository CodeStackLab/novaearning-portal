Options -Indexes

RewriteEngine On
RewriteBase /

# 1. Route API requests to PHP router
RewriteRule ^api/(.*)$ /api/index.php?request=$1 [L,QSA]

# 2. Don't rewrite real existing files (css, js, images, etc)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 3. Don't rewrite existing directories (admin/ etc via physical folder)
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4. Route all else through index.php (clean URL handler)
RewriteRule ^(.*)$ /index.php [L,QSA]
