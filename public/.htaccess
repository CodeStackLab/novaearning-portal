DirectoryIndex index.php login.html index.html
FallbackResource /index.php
ErrorDocument 404 /index.php

RewriteEngine On
RewriteBase /

RewriteRule ^api/(.*)$ api/index.php?request=$1 [L,QSA]

RewriteRule ^dashboard/?$ dashboard.html [L,QSA]
RewriteRule ^user-dashboard/?$ dashboard.html [L,QSA]
RewriteRule ^admin/?$ admin.html [L,QSA]
RewriteRule ^admin-dashboard/?$ admin.html [L,QSA]
RewriteRule ^login/?$ login.html [L,QSA]
RewriteRule ^investments/?$ investments.html [L,QSA]
RewriteRule ^help/?$ help.html [L,QSA]
